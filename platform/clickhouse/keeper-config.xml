<clickhouse>
    <!--
      Single-node ClickHouse with embedded clickhouse-keeper.

      Why this file exists: Langfuse v3's migrations create tables with
      Engine=ReplicatedMergeTree, which requires a Keeper/Zookeeper-style
      coordinator even when there's only one replica. Without this config,
      migrations fail with: "There is no Zookeeper configuration in server
      config".

      This config gives ClickHouse:
      - An embedded keeper on port 9181 so it talks to itself.
      - A <zookeeper> entry that points back at the same node, so any code
        looking up the coordinator finds the embedded keeper.
      - A 1-shard, 1-replica "default" cluster so ON CLUSTER DDL works.
      - Macros so {cluster}/{shard}/{replica} expand correctly in templates.

      Mounted into the official ClickHouse image at:
        /etc/clickhouse-server/config.d/keeper.xml

      Reference: Langfuse v3 self-host docs — single-node deployments.
    -->

    <macros>
        <cluster>default</cluster>
        <shard>01</shard>
        <replica>01</replica>
    </macros>

    <keeper_server>
        <tcp_port>9181</tcp_port>
        <server_id>1</server_id>
        <log_storage_path>/var/lib/clickhouse/coordination/log</log_storage_path>
        <snapshot_storage_path>/var/lib/clickhouse/coordination/snapshots</snapshot_storage_path>
        <coordination_settings>
            <operation_timeout_ms>10000</operation_timeout_ms>
            <session_timeout_ms>30000</session_timeout_ms>
            <raft_logs_level>information</raft_logs_level>
        </coordination_settings>
        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>langfuse-clickhouse</hostname>
                <port>9234</port>
            </server>
        </raft_configuration>
    </keeper_server>

    <zookeeper>
        <node>
            <host>langfuse-clickhouse</host>
            <port>9181</port>
        </node>
    </zookeeper>

    <remote_servers>
        <default>
            <shard>
                <internal_replication>true</internal_replication>
                <replica>
                    <host>langfuse-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </default>
    </remote_servers>
</clickhouse>
