# ============================================================
# SECURITY: NEVER commit credentials or secrets
# ============================================================
.env
.env.local
.env.*.local
*.env
setEnv*.bat
setEnvAWS*.bat

# Python
# Use ** prefixes so nested directories (e.g. tools/data-mcp/__pycache__) are
# excluded regardless of depth — prevents accidentally committing cache dirs
# that were already present in git history.
**/__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
**/*.egg-info/
dist/
build/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
.coverage
**/.coverage
htmlcov/

# Test output
test-results/
*.xml

# Node
node_modules/
npm-debug.log*

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
.terraform.lock.hcl
*.tfvars
!environments/*.tfvars

# Git worktrees — isolated workspaces for branch-per-feature workflows
.worktrees/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Local tool binaries — install via package manager, never commit
skaffold
skaffold.exe
opa
opa.exe
helm
kubectl
".env copy" 
