# Copy this file to .env.local for local development

# URL of the RM Prep Agent FastAPI backend.
# In dev, Vite proxies /api/* to this URL automatically.
# In production (Docker), nginx handles the proxy — this var is unused at runtime.
VITE_AGENT_URL=http://localhost:8003

# Internal API key — must match INTERNAL_API_KEY set on the agent backend.
# Leave empty to disable auth (development only).
VITE_API_KEY=
