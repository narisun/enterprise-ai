# ============================================================
# enterprise-ai — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- Azure OpenAI (LiteLLM local routing) ------------------
AZURE_API_KEY=your-azure-openai-api-key-here
AZURE_API_BASE=https://your-deployment.openai.azure.com
AZURE_API_VERSION=2024-02-15-preview

# ---- AWS Bedrock (LiteLLM prod routing) --------------------
# These are used by litellm-prod.yaml via EKS IRSA in production.
# For local AWS testing only:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ---- Shared Internal API Key --------------------------------
# Used by: LiteLLM master_key, agent service authentication.
# Generate with: python -c "import secrets; print('sk-ent-' + secrets.token_hex(24))"
INTERNAL_API_KEY=sk-ent-replace-with-generated-key

# ---- PostgreSQL ---------------------------------------------
POSTGRES_PASSWORD=replace-with-strong-local-password

# ---- Redis (H5) ---------------------------------------------
# Required by LiteLLM for authenticated response caching.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
REDIS_PASSWORD=replace-with-strong-redis-password

# ---- MCP Server identity ------------------------------------
# H3: server-stamped into every OPA evaluation — callers cannot override.
# Use "local" for local dev (bypasses agent_role check in OPA).
# In production this is set by the Helm values file.
ENVIRONMENT=local
# Must match one of the allowed roles in tools/policies/opa/tool_auth.rego.
AGENT_ROLE=data_analyst_agent

# ---- Observability (Dynatrace) ------------------------------
# Leave blank to disable remote export (local console only).
DYNATRACE_ENDPOINT=https://your-tenant.live.dynatrace.com
DYNATRACE_API_TOKEN=dt0c01.your-token-here

# ---- Chat UI (Chainlit) -------------------------------------
# Chainlit uses this to sign session JWTs. Required when auth is enabled.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
CHAINLIT_AUTH_SECRET=replace-with-generated-secret

# DATABASE_URL is NOT set here — docker-compose assembles it automatically from
# POSTGRES_PASSWORD above:
#   postgresql+asyncpg://admin:${POSTGRES_PASSWORD}@pgvector:5432/ai_memory
# This powers Chainlit's conversation history sidebar (SQLAlchemyDataLayer).
# Tables are created automatically on first startup — no migration step needed.

# Shown in the Help modal (profile dropdown → Help) so users know which
# environment and release they are running.
# APP_ENV badge colours: production=green  staging=amber  anything-else=blue
APP_VERSION=1.0.0
APP_ENV=development

# ---- Agent behaviour (platform_sdk.AgentConfig) ----------------------------
# All optional — defaults shown.  Change without rebuilding Docker images.
#
# Model routes must match names in platform/config/litellm-local.yaml
AGENT_MODEL_ROUTE=complex-routing
SUMMARY_MODEL_ROUTE=fast-routing
#
# Context compaction: trims oldest messages when the token budget is exceeded
# to prevent context-overflow errors and control LLM spend.
ENABLE_COMPACTION=true
AGENT_CONTEXT_TOKEN_LIMIT=6000
#
# Maximum LangGraph tool-call iterations per request (hard-clamped 1–50)
AGENT_RECURSION_LIMIT=10
#
# Maximum user message length in bytes (prevents runaway token spend)
MAX_MESSAGE_LENGTH=32000

# ---- Tool-result caching (platform_sdk.ToolResultCache) -------------------
# Caches MCP tool results in Redis to save repeated DB round-trips.
# Set ENABLE_TOOL_CACHE=false to disable without changing infrastructure.
ENABLE_TOOL_CACHE=true
TOOL_CACHE_TTL=300     # seconds — tune based on how frequently your data changes

# ---- Service URLs (used outside Docker, e.g. running agents locally) ----
LITELLM_BASE_URL=http://localhost:4000/v1
MCP_SSE_URL=http://localhost:8080/sse
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
