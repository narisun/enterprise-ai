# ============================================================
# enterprise-ai — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- Azure OpenAI (primary LLM provider) -------------------
AZURE_API_KEY=your-azure-openai-api-key-here
AZURE_API_BASE=https://your-resource.openai.azure.com
AZURE_API_VERSION=2024-10-21

# ---- Shared Internal API Key --------------------------------
# Used by: LiteLLM master_key, agent service authentication.
# Generate with: python -c "import secrets; print('sk-ent-' + secrets.token_hex(24))"
INTERNAL_API_KEY=sk-ent-replace-with-generated-key

# ---- JWT + Context header secrets ---------------------------
# JWT_SECRET:          Signs RM session JWTs issued at login.
# CONTEXT_HMAC_SECRET: Signs X-Agent-Context headers forwarded from the
#                      orchestrator to MCP servers.  Use a DIFFERENT value
#                      from JWT_SECRET so a JWT compromise alone is not
#                      sufficient to forge MCP context headers.
# Generate each with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-generated-secret
CONTEXT_HMAC_SECRET=replace-with-different-generated-secret

# ---- PostgreSQL ---------------------------------------------
POSTGRES_PASSWORD=replace-with-strong-local-password

# ---- Redis (H5) ---------------------------------------------
REDIS_PASSWORD=replace-with-strong-redis-password

# ---- MCP Server identity ------------------------------------
ENVIRONMENT=local
AGENT_ROLE=data_analyst_agent

# ---- Observability (Dynatrace — optional, legacy) ---------------
DYNATRACE_ENDPOINT=https://your-tenant.live.dynatrace.com
DYNATRACE_API_TOKEN=dt0c01.your-token-here

# ---- LangFuse (LLM Observability + Prompt Management) --------
# These keys are auto-provisioned on LangFuse startup via LANGFUSE_INIT_*
# env vars in docker-compose.infra.yml. Generate your own UUIDs or use these defaults.
# No manual project setup required — just start the stack.
LANGFUSE_PUBLIC_KEY=pk-lf-c7fe9c50-1a46-4160-a749-87b16e11d6f5
LANGFUSE_SECRET_KEY=sk-lf-624994c8-a03c-4188-8317-b2a7aca550a8
# For self-hosted Docker setup (default, no change needed):
LANGFUSE_HOST=http://langfuse:3000
# LangFuse internal DB password (only for local dev):
LANGFUSE_DB_PASSWORD=langfuse-local-dev
LANGFUSE_NEXTAUTH_SECRET=langfuse-dev-secret-change-me
LANGFUSE_SALT=langfuse-dev-salt-change-me
# LangFuse init user (auto-created on first startup):
LANGFUSE_INIT_USER_EMAIL=admin@local.dev
LANGFUSE_INIT_USER_PASSWORD=admin

# ---- Chat UI (Chainlit) -------------------------------------
CHAINLIT_AUTH_SECRET=replace-with-generated-secret

APP_VERSION=1.0.0
APP_ENV=development

# ---- Agent behaviour (platform_sdk.AgentConfig) ----------------------------
# Model route names must match names in platform/config/litellm-local.yaml
AGENT_MODEL_ROUTE=complex-routing
SUMMARY_MODEL_ROUTE=fast-routing
#
# Multi-agent model tiering (used by specialized agents)
ROUTER_MODEL_ROUTE=fast-routing
SPECIALIST_MODEL_ROUTE=fast-routing
SYNTHESIS_MODEL_ROUTE=complex-routing
#
# Session / checkpointer — "memory" for dev, "postgres" for prod
CHECKPOINTER_TYPE=memory
CHECKPOINTER_DB_URL=
#
ENABLE_COMPACTION=true
AGENT_CONTEXT_TOKEN_LIMIT=6000
AGENT_RECURSION_LIMIT=10
MAX_MESSAGE_LENGTH=32000

# ---- Tool-result caching ------------------------------------
ENABLE_TOOL_CACHE=true
TOOL_CACHE_TTL=300

# ---- Service URLs (used outside Docker, e.g. running agents locally) --------
LITELLM_BASE_URL=http://localhost:4000/v1
MCP_SSE_URL=http://localhost:8080/sse
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ---- MCP service URLs (override when running outside Docker) --------
SALESFORCE_MCP_URL=http://localhost:8081/sse
PAYMENTS_MCP_URL=http://localhost:8082/sse
NEWS_MCP_URL=http://localhost:8083/sse

# ---- News Search (Phase 1) --------------------------------------------------
# Tavily API key for real news search. Leave blank to use mock data in dev.
TAVILY_API_KEY=
